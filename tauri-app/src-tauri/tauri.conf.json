{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Stall Tauri",
  "version": "0.1.0",
  "identifier": "voice.stall.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VOICE STALL V2",
        "width": 900,
        "height": 760,
        "minWidth": 100,
        "minHeight": 50,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}