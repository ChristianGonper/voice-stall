{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Stall Tauri",
  "version": "0.1.0",
  "identifier": "voice.stall.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voice Stall Tauri",
        "width": 900,
        "height": 760,
        "resizable": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
